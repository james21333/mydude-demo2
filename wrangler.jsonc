{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mydude-demo2",
  "main": "src/index.js",
  "compatibility_date": "2026-05-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "ai": {
    "binding": "AI"
  },
  "workers_dev": true,
  "routes": [
    {
      "pattern": "demo2.mydude.live/*",
      "zone_name": "mydude.live"
    }
  ],
  "observability": {
    "enabled": true
  }
}
